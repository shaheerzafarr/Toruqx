PROJECT_NAME="Toruqx Secure RAG Engine"
ENV=development
LOG_LEVEL=INFO

# Databases
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@localhost:5432/rag_db
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# LLM & Embeddings
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Security — REQUIRED, generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_REQUIRED
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_SIZE_MB=50

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITEKEY=YOUR_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY
BYPASS_TURNSTILE=true
